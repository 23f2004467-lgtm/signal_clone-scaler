# Production values, set in Vercel project settings (Production AND Preview).
# NEXT_PUBLIC_* values are baked into the JS bundle at `next build` time by
# Vercel — changing one later requires a redeploy, not just a dashboard edit.
# Note https -> wss: the https page blocks plain ws:// as mixed content.
NEXT_PUBLIC_API_URL=https://<your-service>.onrender.com
NEXT_PUBLIC_WS_URL=wss://<your-service>.onrender.com
